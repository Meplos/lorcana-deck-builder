// Package http : handler.go - Cards HTTP Controller
package http

import (
	"log/slog"
	"net/http"
	"strconv"

	"github.com/labstack/echo/v5"
	"github.com/meplos/locana-deck-builder/internal/cards"
)

type Handler struct {
	ListUC *cards.ListCardUC
}

func NewHandler(listUc *cards.ListCardUC) *Handler {
	return &Handler{
		ListUC: listUc,
	}
}

func (h *Handler) ListCard(ctx *echo.Context) error {
	var body PaginateRequest
	if err := ctx.Bind(&body); err != nil {
		return ctx.JSON(http.StatusBadRequest, nil)
	}

	if body.PageNumber == 0 {
		body.PageNumber = 1
	}
	if body.Limit == 0 {
		body.Limit = 20
	}

	response := h.ListUC.ListCards(ctx.Request().Context(), cards.ListCardParams{
		Page:   int64(body.PageNumber),
		Limit:  int64(body.Limit),
		Search: body.Search,
		Color:  body.Color,
	})
	ctx.Logger().Info("List cards", slog.Attr{
		Key: "data",
		Value: response.Docs,
	}))

	cards := make([]CardDTO, 0)
	for _, d := range response.Docs {
		cards = append(cards, BuildCardDTO(d))
	}

	return ctx.JSON(http.StatusOK, PaginateResponse{
		Page:  body.PageNumber,
		Docs:  cards,
		Total: uint(response.Total),
		Size:  uint(response.Size),
	})
}
